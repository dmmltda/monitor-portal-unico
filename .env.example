# ----- Banco (SQLite local; no Railway use um volume, ex: file:/data/prod.db) -----
DATABASE_URL="file:./prisma/dev.db"

# ----- Servidor -----
PORT=8080
# Fuso usado para o agendamento do relatorio diario (18:00)
TZ=America/Sao_Paulo

# ----- Probe -----
# Intervalo entre verificacoes (cron). Padrao: a cada 2 minutos.
PROBE_CRON="*/2 * * * *"
# Timeout de cada requisicao em ms
PROBE_TIMEOUT_MS=10000

# ----- Relatorio diario por e-mail -----
DAILY_REPORT_CRON="0 18 * * *"
# Liga/desliga o envio (use false em dev)
DAILY_REPORT_ENABLED=true

# ----- Resend (https://resend.com) -----
RESEND_API_KEY=""
# Remetente verificado no Resend (ex: "Monitor Portal Unico <monitor@seu-dominio.com>")
EMAIL_FROM="Monitor Portal Unico <onboarding@resend.dev>"

# ----- Check autenticado no Portal Unico (mTLS) — OPCIONAL -----
# Se preenchido, adiciona um servico "API Autenticada (mTLS)" ao dashboard que
# autentica de verdade no PU usando seu certificado A1 (.pfx) e mede se a API
# devolve o token. Deixe tudo vazio para nao habilitar.
#
# Local (dev): aponte para o arquivo .pfx.
PU_CERT_PFX_PATH=""
# Railway/produção: em vez do arquivo, cole o .pfx em base64 aqui.
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("C:\caminho\cert.pfx")) > cert.b64.txt
PU_CERT_PFX_BASE64=""
# Senha do certificado .pfx
PU_CERT_PASSPHRASE=""
# Perfil enviado no header Role-Type (e-CPF: IMPEXP, DESPACHANTE, TRANSPORTADOR, ...)
PU_ROLE_TYPE="IMPEXP"
# Ambiente do check autenticado: prod | val
PU_AUTH_ENV="prod"

# ----- Admin (gerenciar contatos via API) -----
# Token simples exigido no header "x-admin-token" para rotas de escrita de contatos.
ADMIN_TOKEN="troque-este-token"

# ----- Front -----
# URL publica do site (usada em links do e-mail). Em dev pode deixar vazio.
PUBLIC_BASE_URL=""
