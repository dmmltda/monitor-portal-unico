// Monitor Portal Unico — schema (SQLite via Prisma)
// Dados pequenos e append-only; SQLite + volume persistente no Railway.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Resultado de cada verificacao (probe) de um alvo.
model ProbeResult {
  id         String   @id @default(cuid())
  targetKey  String
  checkedAt  DateTime @default(now())
  ok         Boolean
  statusCode Int?
  latencyMs  Int?
  error      String?

  @@index([targetKey, checkedAt])
  @@index([checkedAt])
}

/// Incidente: periodo continuo em que um alvo ficou indisponivel.
/// Aberto quando o alvo transita de "no ar" -> "fora"; fechado na volta.
model Incident {
  id           String    @id @default(cuid())
  targetKey    String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  lastError    String?
  // Quantas verificacoes falhas ocorreram durante o incidente.
  failedChecks Int       @default(1)

  @@index([targetKey, startedAt])
  @@index([endedAt])
}

/// Trava de envio: garante 1 relatorio por dia por destinatario.
/// A unique [reportDate, email] e a barreira fisica contra envios duplicados —
/// uma 2a tentativa no mesmo dia falha no banco (P2002) e e ignorada.
model DailyReportSend {
  id         String   @id @default(cuid())
  reportDate String // YYYY-MM-DD no fuso configurado (env.TZ)
  email      String
  sentAt     DateTime @default(now())

  @@unique([reportDate, email])
  @@index([reportDate])
}

/// Historico/auditoria de cada envio (enviado ou falhou). Separado da trava.
model EmailLog {
  id         String   @id @default(cuid())
  reportDate String // YYYY-MM-DD no fuso
  email      String
  sentAt     DateTime @default(now())
  status     String // 'sent' | 'failed'
  error      String?
  providerId String? // id da mensagem no Resend, quando enviado

  @@index([sentAt])
  @@index([reportDate])
  @@index([status])
}

/// Configuracoes editaveis em runtime (ex: agendamento do relatorio ligado/desligado).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Contato que recebe o relatorio diario.
model Contact {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  // Token unico para o link de cancelamento (so desinscreve este contato).
  unsubscribeToken String?  @unique
}
